<Window x:Class="GymAdminPanel.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie" Height="350" Width="300" WindowStartupLocation="CenterScreen">

    <Grid Background="#F8F9FA" Margin="20">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="Logowanie do systemu" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#2C3E50"/>

            <TextBlock Text="E-mail" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                     Height="30" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Hasło" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
                     Height="30" Padding="5" Margin="0,0,0,20"/>

            <Button Content="Zaloguj się" Command="{Binding LoginCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="40" Background="#2C3E50" Foreground="White" FontWeight="Bold" Cursor="Hand"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" 
                       HorizontalAlignment="Center" Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>