<Window x:Class="GymAdminPanel.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="450" Width="800" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="GYM ADMIN" Foreground="White" FontSize="20" 
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,30"/>

                    <Button Content="👥 Klienci" Margin="0,0,0,5" Padding="5"/>
                    <Button Content="📅 Grafik" Margin="0,0,0,5" Padding="5"/>
                    <Button Content="💪 Trenerzy" Margin="0,0,0,5" Padding="5"/>
                    <Button Content="⚙️ Ustawienia" Margin="0,0,0,5" Padding="5"/>
                </StackPanel>

                <Button Grid.Row="1" Content="🚪 Wyloguj" Command="{Binding LogoutCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                        Background="#C0392B" Foreground="White" FontWeight="Bold" Padding="10" Cursor="Hand"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Zarządzanie Klientami" FontSize="28" FontWeight="Light" Margin="0,0,0,20"/>

                <Button Content="Dodaj nowego klienta" Width="180" HorizontalAlignment="Left" Margin="0,0,0,10"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Clients}" 
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="White" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="Imię" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="Nazwisko" Binding="{Binding LastName}" Width="*"/>
                    <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="1.5*"/>
                    <DataGridTextColumn Header="Rola" Binding="{Binding Role}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>