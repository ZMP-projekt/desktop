<Window x:Class="GymAdminPanel.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejestracja" Height="450" Width="300" WindowStartupLocation="CenterScreen">
    <Grid Background="#F8F9FA" Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Nowe Konto" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#2C3E50"/>

            <TextBlock Text="Imię" Foreground="Gray"/>
            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

            <TextBlock Text="Nazwisko" Foreground="Gray"/>
            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

            <TextBlock Text="E-mail" Foreground="Gray"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

            <TextBlock Text="Hasło" Foreground="Gray"/>
            <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" Padding="5"/>

            <Button Content="Zarejestruj się" Command="{Binding RegisterCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="40" Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand"/>

            <TextBlock Text="{Binding Message}" Foreground="Red" HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>